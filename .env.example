APP_NAME=Resmenu
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Import database/schema/sigsolmenu_resmenu.sql before first run (see docs/STANDALONE_DEPLOYMENT.md)
# Staging/dev: sigsolmenu_resmenu_laravel | Production: sigsolmenu_resmenu
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sigsolmenu_resmenu_laravel
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_CHARSET=utf8mb4

SESSION_DRIVER=file
SESSION_LIFETIME=1440

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=public
UPLOAD_ROOT=
UPLOAD_URL="${APP_URL}/storage/uploads"
# CANONICAL_UPLOAD_URL=https://our-menu.online/storage/uploads

AUTH_SESSION_IDLE_SECONDS=3600
PASSWORD_MIN_LENGTH=8
APP_HMAC_SECRET=
PAYMENT_ENCRYPTION_KEY=
TRUST_PROXY_HEADERS=false

SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

IMAGE_MAX_BYTES=512000
IMAGE_UPLOAD_MAX_BYTES=1048576
MAX_FILE_SIZE=5242880

MAIL_ENABLED=true
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@resmenu.net
MAIL_FROM_NAME="${APP_NAME}"
MAIL_PHP_FALLBACK_ENABLED=true

ZEPTOMAIL_SENDMAIL_TOKEN=
ZEPTOMAIL_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_FROM_ADDRESS=noreply@resmenu.net
ZEPTOMAIL_FROM_NAME="${APP_NAME}"
ZEPTOMAIL_REPLY_TO=support@resmenu.net
ZEPTOMAIL_TIMEOUT_SECONDS=30

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_TIMEOUT_SECONDS=5

REG_OTP_LIMIT_PER_EMAIL=3
REG_OTP_EMAIL_WINDOW_SECONDS=3600
REG_OTP_LIMIT_PER_IP=5
REG_OTP_IP_WINDOW_SECONDS=3600
REG_OTP_LIMIT_GLOBAL=8
REG_OTP_GLOBAL_WINDOW_SECONDS=60
REG_OTP_COOLDOWN_EMAIL_SECONDS=60
REG_OTP_COOLDOWN_IP_SECONDS=60
REG_OTP_TTL_MINUTES=10
REG_OTP_STRICT_LOCAL_PART=false
REG_OTP_BOUNCE_WEBHOOK_SECRET=

VITE_APP_NAME="${APP_NAME}"
